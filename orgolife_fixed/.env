# OrgoLife — Environment Configuration
# ─────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (default):
#   MONGODB_URL=mongodb://localhost:27017
#
# MONGODB ATLAS (cloud):
#   MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#
# ── App ──────────────────────────────────────────────────────────
APP_NAME=OrgoLife Organ Donation Platform
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ── MongoDB ──────────────────────────────────────────────────────
# Replace with your MongoDB Atlas URI for cloud deployment.
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=organ_donation_db

# ── JWT Security ─────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=orgolife-dev-secret-change-in-production-use-secrets-token-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File Upload ──────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ── CORS ─────────────────────────────────────────────────────────
# Add your frontend origin if deploying separately.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500,http://localhost:8000

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
